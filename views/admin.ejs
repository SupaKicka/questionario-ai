<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin — Autovalutazione AI</title>
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --navy: #0f1c2e; --navy2: #1a2e47; --navy3: #243a55;
      --blue: #2f6fef; --blue-l: #e8f0fe;
      --green: #10b981; --green-l: #d1fae5;
      --amber: #f59e0b; --amber-l: #fef3c7;
      --red: #ef4444; --red-l: #fee2e2;
      --text: #1a1a2e; --muted: #6b7280; --border: #e5e7eb;
      --bg: #f0f2f6; --card: #fff;
      --r: 12px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); }

    /* ── Top bar ── */
    .topbar {
      background: linear-gradient(135deg, var(--navy) 0%, var(--navy2) 100%);
      color: #fff; padding: 0 32px; height: 64px;
      display: flex; justify-content: space-between; align-items: center;
      position: sticky; top: 0; z-index: 100;
    }
    .topbar-brand { display: flex; align-items: center; gap: 12px; }
    .topbar-brand img { width: 36px; height: 36px; object-fit: contain; }
    .topbar-brand span { font-size: 16px; font-weight: 700; letter-spacing: -.2px; }
    .topbar-brand small { font-size: 11px; opacity: .5; display: block; }
    .topbar-nav { display: flex; gap: 20px; align-items: center; }
    .topbar-nav a { color: rgba(255,255,255,.65); text-decoration: none; font-size: 13px; font-weight: 500; transition: color .2s; }
    .topbar-nav a:hover { color: #fff; }

    /* ── Layout ── */
    .page { max-width: 1080px; margin: 0 auto; padding: 28px 20px 60px; }

    /* ── KPI row ── */
    .kpi-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 14px; margin-bottom: 28px; }
    .kpi { background: var(--card); border-radius: var(--r); padding: 20px 22px; box-shadow: 0 1px 3px rgba(0,0,0,.06); }
    .kpi .val { font-size: 32px; font-weight: 800; line-height: 1; }
    .kpi .lbl { font-size: 12px; color: var(--muted); margin-top: 5px; text-transform: uppercase; letter-spacing: .5px; font-weight: 600; }
    .kpi.blue .val { color: var(--blue); }
    .kpi.green .val { color: var(--green); }
    .kpi.amber .val { color: var(--amber); }
    .kpi .sub { font-size: 11px; color: var(--muted); margin-top: 4px; }

    /* ── Cards ── */
    .card { background: var(--card); border-radius: var(--r); padding: 24px 28px; box-shadow: 0 1px 3px rgba(0,0,0,.06); margin-bottom: 20px; }
    .card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .card-title { font-size: 15px; font-weight: 700; color: var(--text); }
    .card-subtitle { font-size: 12px; color: var(--muted); margin-top: 2px; }

    /* ── Add company form ── */
    .add-row { display: flex; gap: 10px; }
    .add-row input[type=text] { flex: 1; padding: 11px 14px; border: 1.5px solid var(--border); border-radius: 9px; font-size: 14px; font-family: inherit; outline: none; transition: border .2s; }
    .add-row input:focus { border-color: var(--blue); box-shadow: 0 0 0 3px rgba(47,111,239,.1); }
    .btn { padding: 10px 20px; border: none; border-radius: 9px; font-size: 13px; font-weight: 700; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; transition: all .18s; font-family: inherit; }
    .btn-primary { background: var(--navy); color: #fff; }
    .btn-primary:hover { background: #0a1422; }
    .btn-sm { padding: 7px 14px; font-size: 12px; }
    .btn-danger { background: var(--red-l); color: #b91c1c; }
    .btn-danger:hover { background: #fecaca; }
    .btn-outline { background: transparent; border: 1.5px solid var(--border); color: var(--text); }
    .btn-outline:hover { background: var(--bg); }
    .btn-green { background: var(--green-l); color: #065f46; }
    .btn-green:hover { background: #a7f3d0; }

    /* ── Companies table ── */
    table { width: 100%; border-collapse: collapse; }
    thead th { text-align: left; font-size: 11px; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: .6px; padding: 8px 12px; border-bottom: 2px solid var(--border); }
    tbody td { padding: 14px 12px; border-bottom: 1px solid #f3f4f6; font-size: 13px; vertical-align: middle; }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover td { background: #fafbfc; }

    .company-name { font-weight: 700; font-size: 14px; }
    .created-date { font-size: 11px; color: var(--muted); font-family: 'DM Mono', monospace; margin-top: 2px; }

    /* ── Link box ── */
    .link-box { display: flex; align-items: center; gap: 6px; }
    .link-box code { background: var(--bg); padding: 5px 10px; border-radius: 7px; font-size: 11px; font-family: 'DM Mono', monospace; color: var(--muted); max-width: 260px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .copy-btn { background: none; border: 1.5px solid var(--border); border-radius: 6px; padding: 4px 9px; cursor: pointer; font-size: 11px; color: var(--muted); font-family: inherit; font-weight: 600; transition: all .15s; }
    .copy-btn:hover { background: var(--blue-l); border-color: var(--blue); color: var(--blue); }
    .copy-btn.copied { background: var(--green-l); border-color: var(--green); color: var(--green); }

    /* ── Score mini bar ── */
    .score-cell { min-width: 120px; }
    .score-avg { font-size: 13px; font-weight: 700; margin-bottom: 4px; }
    .mini-bar-bg { height: 6px; background: #f0f0f0; border-radius: 10px; overflow: hidden; width: 100px; }
    .mini-bar-fill { height: 100%; border-radius: 10px; transition: width .5s; }

    /* ── Level pills ── */
    .level-dist { display: flex; gap: 4px; flex-wrap: wrap; }
    .lpill { font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 10px; }
    .lpill.p { background: var(--red-l); color: #b91c1c; }
    .lpill.i { background: var(--amber-l); color: #92400e; }
    .lpill.a { background: var(--green-l); color: #065f46; }

    /* ── Actions ── */
    .actions { display: flex; gap: 6px; align-items: center; }

    /* ── Response count ── */
    .resp-count { font-size: 18px; font-weight: 800; color: var(--blue); }
    .resp-label { font-size: 11px; color: var(--muted); }

    /* ── Empty state ── */
    .empty { text-align: center; padding: 48px 20px; color: var(--muted); }
    .empty-icon { font-size: 40px; margin-bottom: 12px; }
    .empty p { font-size: 14px; }

    /* ── Legend ── */
    .legend { display: flex; gap: 20px; font-size: 11px; color: var(--muted); margin-top: 12px; flex-wrap: wrap; }
    .legend-item { display: flex; align-items: center; gap: 5px; }
    .legend-dot { width: 10px; height: 10px; border-radius: 3px; }
  </style>
</head>
<body>
  <div class="topbar">
    <div class="topbar-brand">
      <img src="/logo.png" alt="">
      <div>
        <span>Autovalutazione AI</span>
        <small>Pannello Admin</small>
      </div>
    </div>
    <div class="topbar-nav">
      <a href="/admin">Dashboard</a>
      <a href="/admin/logout">Esci →</a>
    </div>
  </div>

  <div class="page">

    <!-- KPI row -->
    <%
      const totalResp = totals ? (totals.total_responses || 0) : 0;
      const globalAvg = totals && totals.global_avg ? (totals.global_avg / numQuestions).toFixed(1) : null;
    %>
    <div class="kpi-row">
      <div class="kpi blue">
        <div class="val"><%= companies.length %></div>
        <div class="lbl">Aziende</div>
        <div class="sub">attive nella piattaforma</div>
      </div>
      <div class="kpi">
        <div class="val"><%= totalResp %></div>
        <div class="lbl">Risposte totali</div>
        <div class="sub">su tutte le aziende</div>
      </div>
      <% if (globalAvg) { %>
      <div class="kpi green">
        <div class="val"><%= globalAvg %><span style="font-size:16px;font-weight:500;color:#6b7280">/5</span></div>
        <div class="lbl">Media globale</div>
        <div class="sub">punteggio medio per domanda</div>
      </div>
      <% } %>
      <div class="kpi amber">
        <div class="val"><%= numQuestions %></div>
        <div class="lbl">Domande</div>
        <div class="sub">+ 2 domande aperte</div>
      </div>
    </div>

    <!-- Add company -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">Nuova azienda</div>
          <div class="card-subtitle">Aggiungi un'azienda per generare il link del questionario</div>
        </div>
      </div>
      <form method="POST" action="/admin/companies" class="add-row">
        <input type="text" name="name" placeholder="Nome dell'azienda (es. Acme Srl, Tech Group…)" required>
        <button type="submit" class="btn btn-primary">+ Aggiungi</button>
      </form>
    </div>

    <!-- Companies list -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">Aziende (<%= companies.length %>)</div>
          <div class="card-subtitle">Clicca su "Risultati" per vedere i dettagli di ogni azienda</div>
        </div>
      </div>

      <% if (companies.length === 0) { %>
        <div class="empty">
          <div class="empty-icon">🏢</div>
          <p>Nessuna azienda inserita ancora.<br>Aggiungi la prima usando il modulo qui sopra.</p>
        </div>
      <% } else { %>
        <div style="overflow-x:auto">
          <table>
            <thead>
              <tr>
                <th>Azienda</th>
                <th>Link questionario</th>
                <th>Risposte</th>
                <th>Media /5</th>
                <th>Distribuzione livelli</th>
                <th style="text-align:right">Azioni</th>
              </tr>
            </thead>
            <tbody>
              <% for (const c of companies) { %>
                <% const testUrl = protocol + '://' + host + '/test/' + c.slug; %>
                <% const avgPer5 = c.avg_score ? (c.avg_score / numQuestions).toFixed(1) : null; %>
                <% const avgPct = avgPer5 ? Math.round(parseFloat(avgPer5)/5*100) : 0; %>
                <%
                  let barColor = '#6b7280';
                  if (avgPer5) {
                    const a = parseFloat(avgPer5);
                    barColor = a <= 2 ? '#ef4444' : a <= 3.5 ? '#f59e0b' : '#10b981';
                  }
                %>
                <tr>
                  <td>
                    <div class="company-name"><%= c.name %></div>
                    <div class="created-date"><%= new Date(c.created_at + 'Z').toLocaleDateString('it-IT') %></div>
                  </td>
                  <td>
                    <div class="link-box">
                      <code id="link-<%= c.id %>"><%= testUrl %></code>
                      <button class="copy-btn" id="copy-<%= c.id %>" onclick="copyLink('<%= c.id %>')">Copia</button>
                    </div>
                  </td>
                  <td>
                    <div class="resp-count"><%= c.response_count %></div>
                    <div class="resp-label">risposte</div>
                  </td>
                  <td class="score-cell">
                    <% if (avgPer5) { %>
                      <div class="score-avg" style="color:<%= barColor %>"><%= avgPer5 %>/5</div>
                      <div class="mini-bar-bg">
                        <div class="mini-bar-fill" style="width:<%= avgPct %>%;background:<%= barColor %>"></div>
                      </div>
                    <% } else { %>
                      <span style="color:var(--muted);font-size:12px">—</span>
                    <% } %>
                  </td>
                  <td>
                    <div class="level-dist">
                      <% if (c.n_principiante > 0) { %><span class="lpill p"><%= c.n_principiante %> Princ.</span><% } %>
                      <% if (c.n_intermedio > 0) { %><span class="lpill i"><%= c.n_intermedio %> Inter.</span><% } %>
                      <% if (c.n_avanzato > 0) { %><span class="lpill a"><%= c.n_avanzato %> Avanz.</span><% } %>
                      <% if (!c.response_count) { %><span style="font-size:12px;color:var(--muted)">—</span><% } %>
                    </div>
                  </td>
                  <td>
                    <div class="actions" style="justify-content:flex-end">
                      <a href="/admin/companies/<%= c.id %>" class="btn btn-outline btn-sm">Risultati</a>
                      <form method="POST" action="/admin/companies/<%= c.id %>/delete"
                            onsubmit="return confirm('Eliminare <%= c.name %> e tutti i risultati?')">
                        <button type="submit" class="btn btn-danger btn-sm">Elimina</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
        <div class="legend">
          <div class="legend-item"><div class="legend-dot" style="background:#ef4444"></div> Principiante (media ≤ 2.0)</div>
          <div class="legend-item"><div class="legend-dot" style="background:#f59e0b"></div> Intermedio (media 2.1–3.5)</div>
          <div class="legend-item"><div class="legend-dot" style="background:#10b981"></div> Avanzato (media > 3.5)</div>
        </div>
      <% } %>
    </div>

  </div>

  <script>
    function copyLink(id) {
      const code = document.getElementById('link-' + id).textContent;
      const btn = document.getElementById('copy-' + id);
      navigator.clipboard.writeText(code).then(() => {
        btn.textContent = '✓ Copiato';
        btn.classList.add('copied');
        setTimeout(() => { btn.textContent = 'Copia'; btn.classList.remove('copied'); }, 2000);
      });
    }
  </script>
</body>
</html>
