<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin — Questionario AI</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f0f2f5; color: #1a1a1a; }
    .topbar { background: #2c3e50; color: #fff; padding: 16px 32px; display: flex; justify-content: space-between; align-items: center; }
    .topbar h1 { font-size: 18px; font-weight: 600; display: flex; align-items: center; gap: 12px; }
    .topbar h1 img { width: 32px; height: 32px; object-fit: contain; }
    .topbar a { color: rgba(255,255,255,.7); text-decoration: none; font-size: 13px; }
    .topbar a:hover { color: #fff; }
    .container { max-width: 960px; margin: 32px auto; padding: 0 20px; }

    .card { background: #fff; border-radius: 12px; padding: 28px 32px; box-shadow: 0 1px 6px rgba(0,0,0,.06); margin-bottom: 24px; }
    .card h2 { font-size: 17px; color: #2c3e50; margin-bottom: 16px; }

    .form-row { display: flex; gap: 12px; }
    .form-row input[type=text] { flex: 1; padding: 10px 14px; border: 1px solid #ddd; border-radius: 8px; font-size: 14px; outline: none; }
    .form-row input[type=text]:focus { border-color: #2c3e50; }
    .btn { padding: 10px 20px; border: none; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; text-decoration: none; display: inline-block; transition: background .2s; }
    .btn-primary { background: #2c3e50; color: #fff; }
    .btn-primary:hover { background: #1a252f; }
    .btn-sm { padding: 6px 14px; font-size: 12px; }
    .btn-danger { background: #fef2f2; color: #b91c1c; }
    .btn-danger:hover { background: #fde8e8; }
    .btn-outline { background: transparent; border: 1px solid #ddd; color: #333; }
    .btn-outline:hover { background: #f5f5f5; }

    table { width: 100%; border-collapse: collapse; }
    thead th { text-align: left; font-size: 12px; font-weight: 600; color: #666; text-transform: uppercase; letter-spacing: .5px; padding: 10px 12px; border-bottom: 2px solid #eee; }
    tbody td { padding: 12px; border-bottom: 1px solid #f0f0f0; font-size: 14px; vertical-align: middle; }
    tbody tr:hover { background: #fafafa; }

    .badge { display: inline-block; padding: 3px 10px; border-radius: 12px; font-size: 12px; font-weight: 600; }
    .badge-count { background: #e8f4f8; color: #2c3e50; }
    .badge-score { background: #f0fdf4; color: #166534; }

    .link-box { display: flex; align-items: center; gap: 8px; }
    .link-box code { background: #f5f5f5; padding: 4px 10px; border-radius: 6px; font-size: 12px; color: #555; word-break: break-all; }
    .copy-btn { background: none; border: 1px solid #ddd; border-radius: 6px; padding: 4px 8px; cursor: pointer; font-size: 11px; color: #666; }
    .copy-btn:hover { background: #f5f5f5; }

    .empty { text-align: center; padding: 40px; color: #999; font-size: 14px; }

    .actions { display: flex; gap: 8px; align-items: center; }
  </style>
</head>
<body>
  <div class="topbar">
    <h1><img src="/logo.png" alt=""> Questionario AI — Admin</h1>
    <a href="/admin/logout">Esci</a>
  </div>

  <div class="container">
    <!-- Add company -->
    <div class="card">
      <h2>Aggiungi azienda</h2>
      <form method="POST" action="/admin/companies" class="form-row">
        <input type="text" name="name" placeholder="Nome dell'azienda" required>
        <button type="submit" class="btn btn-primary">Aggiungi</button>
      </form>
    </div>

    <!-- Companies list -->
    <div class="card">
      <h2>Aziende (<%= companies.length %>)</h2>
      <% if (companies.length === 0) { %>
        <div class="empty">Nessuna azienda inserita</div>
      <% } else { %>
        <table>
          <thead>
            <tr>
              <th>Azienda</th>
              <th>Link test</th>
              <th>Risposte</th>
              <th>Media</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% for (const c of companies) { %>
              <% const testUrl = protocol + '://' + host + '/test/' + c.slug; %>
              <tr>
                <td><strong><%= c.name %></strong></td>
                <td>
                  <div class="link-box">
                    <code id="link-<%= c.id %>"><%= testUrl %></code>
                    <button class="copy-btn" onclick="copyLink('<%= c.id %>')">Copia</button>
                  </div>
                </td>
                <td><span class="badge badge-count"><%= c.response_count %></span></td>
                <td>
                  <% if (c.avg_score) { %>
                    <span class="badge badge-score"><%= c.avg_score %>/27</span>
                  <% } else { %>
                    <span style="color:#999;font-size:13px">—</span>
                  <% } %>
                </td>
                <td>
                  <div class="actions">
                    <a href="/admin/companies/<%= c.id %>" class="btn btn-outline btn-sm">Risultati</a>
                    <form method="POST" action="/admin/companies/<%= c.id %>/delete"
                          onsubmit="return confirm('Eliminare questa azienda e tutti i risultati?')">
                      <button type="submit" class="btn btn-danger btn-sm">Elimina</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>

  <script>
    function copyLink(id) {
      const code = document.getElementById('link-' + id);
      navigator.clipboard.writeText(code.textContent).then(() => {
        const btn = code.nextElementSibling;
        btn.textContent = 'Copiato!';
        setTimeout(() => btn.textContent = 'Copia', 1500);
      });
    }
  </script>
</body>
</html>
