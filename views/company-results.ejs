<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Risultati — <%= company.name %></title>
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="apple-touch-icon" sizes="192x192" href="/favicon-192.png">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f0f2f5; color: #1a1a1a; }
    .topbar { background: #2c3e50; color: #fff; padding: 16px 32px; display: flex; justify-content: space-between; align-items: center; }
    .topbar h1 { font-size: 18px; font-weight: 600; display: flex; align-items: center; gap: 12px; }
    .topbar h1 img { width: 44px; height: 44px; object-fit: contain; }
    .topbar a { color: rgba(255,255,255,.7); text-decoration: none; font-size: 13px; }
    .topbar a:hover { color: #fff; }
    .container { max-width: 1100px; margin: 32px auto; padding: 0 20px; }

    .card { background: #fff; border-radius: 12px; padding: 28px 32px; box-shadow: 0 1px 6px rgba(0,0,0,.06); margin-bottom: 24px; }
    .card h2 { font-size: 17px; color: #2c3e50; margin-bottom: 16px; }

    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 16px; margin-bottom: 24px; }
    .stat-box { background: #f8f9fa; border-radius: 10px; padding: 20px; text-align: center; }
    .stat-box .value { font-size: 28px; font-weight: 700; color: #2c3e50; }
    .stat-box .label { font-size: 12px; color: #888; margin-top: 4px; text-transform: uppercase; letter-spacing: .5px; }
    .stat-box.principiante .value { color: #dc2626; }
    .stat-box.intermedio .value { color: #d97706; }
    .stat-box.avanzato .value { color: #16a34a; }

    .bar-chart { display: flex; gap: 4px; height: 28px; border-radius: 6px; overflow: hidden; margin-bottom: 8px; }
    .bar-chart .seg { display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 600; color: #fff; min-width: 30px; transition: width .3s; }
    .seg.p { background: #ef4444; }
    .seg.i { background: #f59e0b; }
    .seg.a { background: #22c55e; }

    table { width: 100%; border-collapse: collapse; }
    thead th { text-align: left; font-size: 12px; font-weight: 600; color: #666; text-transform: uppercase; letter-spacing: .5px; padding: 10px 12px; border-bottom: 2px solid #eee; }
    tbody td { padding: 12px; border-bottom: 1px solid #f0f0f0; font-size: 13px; vertical-align: top; }
    tbody tr:hover { background: #fafafa; }

    .level { display: inline-block; padding: 3px 10px; border-radius: 12px; font-size: 11px; font-weight: 700; }
    .level-Principiante { background: #fef2f2; color: #dc2626; }
    .level-Intermedio { background: #fffbeb; color: #d97706; }
    .level-Avanzato { background: #f0fdf4; color: #16a34a; }

    .btn { padding: 10px 20px; border: none; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; text-decoration: none; display: inline-block; transition: background .2s; }
    .btn-outline { background: transparent; border: 1px solid #ddd; color: #333; }
    .btn-outline:hover { background: #f5f5f5; }
    .btn-primary { background: #2c3e50; color: #fff; }
    .btn-primary:hover { background: #1a252f; }
    .btn-sm { padding: 8px 16px; font-size: 13px; }

    .toolbar { display: flex; gap: 12px; align-items: center; margin-bottom: 20px; flex-wrap: wrap; }
    .link-display { background: #f5f5f5; padding: 8px 14px; border-radius: 8px; font-size: 12px; color: #555; word-break: break-all; flex: 1; }

    .open-answer { max-width: 300px; font-size: 12px; color: #555; line-height: 1.4; }
    .empty { text-align: center; padding: 40px; color: #999; font-size: 14px; }

    .detail-toggle { cursor: pointer; color: #2c3e50; font-weight: 600; font-size: 12px; }
    .detail-row { display: none; }
    .detail-row.show { display: table-row; }
    .detail-cell { padding: 12px 12px 20px; background: #fafbfc; }
    .detail-cell .q-item { padding: 4px 0; font-size: 12px; display: flex; gap: 8px; }
    .detail-cell .q-item .correct { color: #16a34a; }
    .detail-cell .q-item .wrong { color: #dc2626; }
  </style>
</head>
<body>
  <div class="topbar">
    <h1><img src="/logo.png" alt=""> Risultati — <%= company.name %></h1>
    <a href="/admin">&larr; Torna alla lista</a>
  </div>

  <div class="container">
    <!-- Stats -->
    <div class="card">
      <div class="stats-grid">
        <div class="stat-box">
          <div class="value"><%= stats.total %></div>
          <div class="label">Risposte totali</div>
        </div>
        <div class="stat-box">
          <div class="value"><%= stats.avgScore %></div>
          <div class="label">Media punteggio</div>
        </div>
        <div class="stat-box principiante">
          <div class="value"><%= stats.principiante %></div>
          <div class="label">Principiante</div>
        </div>
        <div class="stat-box intermedio">
          <div class="value"><%= stats.intermedio %></div>
          <div class="label">Intermedio</div>
        </div>
        <div class="stat-box avanzato">
          <div class="value"><%= stats.avanzato %></div>
          <div class="label">Avanzato</div>
        </div>
      </div>

      <% if (stats.total > 0) { %>
        <% const pPct = (stats.principiante / stats.total * 100).toFixed(0); %>
        <% const iPct = (stats.intermedio / stats.total * 100).toFixed(0); %>
        <% const aPct = (stats.avanzato / stats.total * 100).toFixed(0); %>
        <div class="bar-chart">
          <% if (stats.principiante > 0) { %><div class="seg p" style="width:<%= pPct %>%"><%= pPct %>%</div><% } %>
          <% if (stats.intermedio > 0) { %><div class="seg i" style="width:<%= iPct %>%"><%= iPct %>%</div><% } %>
          <% if (stats.avanzato > 0) { %><div class="seg a" style="width:<%= aPct %>%"><%= aPct %>%</div><% } %>
        </div>
        <div style="display:flex;gap:20px;font-size:11px;color:#888">
          <span style="display:flex;align-items:center;gap:4px"><span style="width:10px;height:10px;border-radius:2px;background:#ef4444;display:inline-block"></span> Principiante</span>
          <span style="display:flex;align-items:center;gap:4px"><span style="width:10px;height:10px;border-radius:2px;background:#f59e0b;display:inline-block"></span> Intermedio</span>
          <span style="display:flex;align-items:center;gap:4px"><span style="width:10px;height:10px;border-radius:2px;background:#22c55e;display:inline-block"></span> Avanzato</span>
        </div>
      <% } %>
    </div>

    <!-- Toolbar -->
    <div class="card">
      <div class="toolbar">
        <% const testUrl = protocol + '://' + host + '/test/' + company.slug; %>
        <span class="link-display"><%= testUrl %></span>
        <button class="btn btn-outline btn-sm" onclick="navigator.clipboard.writeText('<%= testUrl %>')">Copia link</button>
        <% if (stats.total > 0) { %>
          <a href="/admin/companies/<%= company.id %>/export" class="btn btn-primary btn-sm">Esporta CSV</a>
        <% } %>
      </div>
    </div>

    <!-- Responses table -->
    <div class="card">
      <h2>Risposte individuali</h2>
      <% if (responses.length === 0) { %>
        <div class="empty">Nessuna risposta ricevuta</div>
      <% } else { %>
        <div style="overflow-x:auto">
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>Nome</th>
              <th>Ruolo</th>
              <th>Punteggio</th>
              <th>Livello</th>
              <th>Uso AI nel lavoro</th>
              <th>Preoccupazione</th>
              <th>Data</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% responses.forEach((r, idx) => { %>
              <tr>
                <td><%= responses.length - idx %></td>
                <td><strong><%= r.respondent_name || '—' %></strong></td>
                <td><%= r.respondent_role || '—' %></td>
                <td><strong><%= r.score %></strong>/27</td>
                <td><span class="level level-<%= r.level %>"><%= r.level %></span></td>
                <td><div class="open-answer"><%= r.open_20 || '—' %></div></td>
                <td><div class="open-answer"><%= r.open_21 || '—' %></div></td>
                <td style="white-space:nowrap;font-size:12px;color:#888"><%= new Date(r.created_at + 'Z').toLocaleDateString('it-IT', {day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'}) %></td>
                <td><span class="detail-toggle" onclick="toggleDetail(<%= r.id %>)">Dettagli</span></td>
              </tr>
              <tr class="detail-row" id="detail-<%= r.id %>">
                <td colspan="9" class="detail-cell">
                  <% for (const q of questions) { %>
                    <% if (q.correct === null) continue; %>
                    <% const userAns = r.parsedAnswers['q' + q.id]; %>
                    <% const isCorrect = parseInt(userAns) === q.correct; %>
                    <div class="q-item">
                      <span class="<%= isCorrect ? 'correct' : 'wrong' %>"><%= isCorrect ? '✓' : '✗' %></span>
                      <span><strong>D<%= q.id %>:</strong> <%= q.text %></span>
                      <span style="margin-left:auto;color:#888">
                        Risposta: <%= userAns !== undefined ? q.options[parseInt(userAns)] : 'N/A' %>
                        <% if (!isCorrect) { %> — Corretta: <%= q.options[q.correct] %><% } %>
                      </span>
                    </div>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        </div>
      <% } %>
    </div>
  </div>

  <script>
    function toggleDetail(id) {
      document.getElementById('detail-' + id).classList.toggle('show');
    }
  </script>
</body>
</html>
