<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Autovalutazione AI — <%= company.name %></title>
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --navy: #0f1c2e;
      --navy2: #1a2e47;
      --blue: #2f6fef;
      --blue-light: #e8f0fe;
      --green: #10b981;
      --amber: #f59e0b;
      --red: #ef4444;
      --text: #1a1a2e;
      --muted: #6b7280;
      --border: #e5e7eb;
      --bg: #f5f7fa;
      --card: #ffffff;
      --radius: 12px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); line-height: 1.55; }

    /* ── Progress bar ── */
    .prog-wrap { position: fixed; top: 0; left: 0; right: 0; height: 4px; background: rgba(0,0,0,.08); z-index: 999; }
    .prog-bar { height: 100%; background: linear-gradient(90deg, var(--blue), var(--green)); transition: width .4s ease; }

    /* ── Header ── */
    .header {
      background: linear-gradient(135deg, var(--navy) 0%, var(--navy2) 100%);
      color: #fff; padding: 40px 20px 36px; text-align: center;
    }
    .header img { width: 72px; height: 72px; object-fit: contain; display: block; margin: 0 auto 20px; }
    .header h1 { font-size: 24px; font-weight: 700; letter-spacing: -.3px; }
    .header .sub { font-size: 14px; opacity: .7; margin-top: 6px; }
    .header .company-badge {
      display: inline-block; margin-top: 14px; background: rgba(255,255,255,.12);
      padding: 5px 16px; border-radius: 20px; font-size: 13px; font-weight: 600;
    }
    .intro-note {
      max-width: 640px; margin: 0 auto; margin-top: 18px; padding: 14px 18px;
      background: rgba(255,255,255,.09); border-radius: 10px;
      font-size: 13px; color: rgba(255,255,255,.8); line-height: 1.6;
    }

    /* ── Container ── */
    .container { max-width: 700px; margin: 0 auto; padding: 28px 16px 80px; }

    /* ── Section header ── */
    .section-header {
      display: flex; align-items: center; gap: 12px; margin: 32px 0 14px;
    }
    .section-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--blue); flex-shrink: 0; }
    .section-name { font-size: 13px; font-weight: 700; color: var(--blue); text-transform: uppercase; letter-spacing: .8px; }
    .section-line { flex: 1; height: 1px; background: var(--border); }

    /* ── Question card ── */
    .q-card {
      background: var(--card); border-radius: var(--radius); padding: 22px 24px;
      margin-bottom: 12px; box-shadow: 0 1px 3px rgba(0,0,0,.06);
      border: 1.5px solid transparent; transition: border-color .2s;
    }
    .q-card.answered { border-color: #d1fae5; }
    .q-num { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--muted); margin-bottom: 8px; letter-spacing: .4px; }
    .q-text { font-size: 15px; font-weight: 600; color: var(--text); margin-bottom: 16px; line-height: 1.5; }

    /* ── Scale type badge ── */
    .scale-label {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 11px; font-weight: 700; text-transform: uppercase;
      letter-spacing: .6px; padding: 3px 10px; border-radius: 20px;
      margin-bottom: 14px;
    }
    .scale-label.knowledge { background: #eff6ff; color: #2563eb; }
    .scale-label.usage { background: #f0fdf4; color: #16a34a; }

    /* ── Scale buttons ── */
    .scale-row {
      display: flex; gap: 8px; flex-wrap: nowrap;
    }
    .scale-opt { flex: 1; }
    .scale-opt input[type=radio] { display: none; }
    .scale-btn {
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      border: 2px solid var(--border); border-radius: 10px;
      padding: 10px 4px 8px; cursor: pointer; transition: all .18s;
      text-align: center; user-select: none; min-width: 0;
    }
    .scale-btn .num {
      font-size: 18px; font-weight: 700; color: var(--muted); line-height: 1; margin-bottom: 5px;
    }
    .scale-btn .lbl { font-size: 10px; color: var(--muted); line-height: 1.2; font-weight: 500; }
    .scale-btn:hover { border-color: var(--blue); background: var(--blue-light); }
    .scale-btn:hover .num, .scale-btn:hover .lbl { color: var(--blue); }

    .scale-opt input:checked + .scale-btn {
      border-color: var(--blue); background: var(--blue);
    }
    .scale-opt input:checked + .scale-btn .num,
    .scale-opt input:checked + .scale-btn .lbl { color: #fff; }

    /* Color per value */
    .scale-opt:nth-child(1) input:checked + .scale-btn { background: #ef4444; border-color: #ef4444; }
    .scale-opt:nth-child(2) input:checked + .scale-btn { background: #f97316; border-color: #f97316; }
    .scale-opt:nth-child(3) input:checked + .scale-btn { background: #eab308; border-color: #eab308; }
    .scale-opt:nth-child(4) input:checked + .scale-btn { background: #22c55e; border-color: #22c55e; }
    .scale-opt:nth-child(5) input:checked + .scale-btn { background: #10b981; border-color: #10b981; }

    @media (max-width: 500px) {
      .scale-btn { padding: 8px 2px 6px; }
      .scale-btn .num { font-size: 16px; }
      .scale-btn .lbl { font-size: 9px; }
    }

    /* ── Profile card ── */
    .profile-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .field label { display: block; font-size: 12px; font-weight: 700; color: var(--muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: .5px; }
    .text-input { width: 100%; padding: 11px 14px; border: 1.5px solid var(--border); border-radius: 9px; font-size: 14px; font-family: inherit; outline: none; transition: border .2s; }
    .text-input:focus { border-color: var(--blue); box-shadow: 0 0 0 3px rgba(47,111,239,.1); }
    textarea.text-input { min-height: 88px; resize: vertical; }
    @media (max-width: 500px) { .profile-grid { grid-template-columns: 1fr; } }

    /* ── Open questions ── */
    .open-q .q-text { font-size: 15px; font-weight: 600; margin-bottom: 12px; }

    /* ── Submit ── */
    .submit-area { text-align: center; margin-top: 36px; }
    .submit-btn {
      padding: 15px 52px; background: var(--navy); color: #fff;
      border: none; border-radius: 12px; font-size: 16px; font-weight: 700;
      cursor: pointer; transition: background .2s, transform .1s;
      font-family: inherit;
    }
    .submit-btn:hover { background: #0a1422; transform: translateY(-1px); }
    .submit-btn:disabled { opacity: .5; cursor: not-allowed; transform: none; }
    .submit-note { font-size: 12px; color: var(--muted); margin-top: 10px; }

    /* ── Counter ── */
    .counter-bar {
      position: fixed; bottom: 0; left: 0; right: 0;
      background: var(--navy); color: rgba(255,255,255,.8);
      padding: 10px 24px; display: flex; justify-content: space-between; align-items: center;
      font-size: 13px; z-index: 100;
    }
    .counter-bar strong { color: #fff; }
  </style>
</head>
<body>
  <div class="prog-wrap"><div class="prog-bar" id="prog" style="width:0%"></div></div>

  <div class="header">
    <img src="/logo.png" alt="Skillcraft">
    <h1>Autovalutazione AI</h1>
    <div class="sub">Questionario sulle competenze in Intelligenza Artificiale</div>
    <div class="company-badge"><%= company.name %></div>
    <div class="intro-note">
      Non ci sono risposte giuste o sbagliate. Indica onestamente quanto conosci o utilizzi
      ciascun argomento su una scala da <strong>1</strong> (per niente) a <strong>5</strong> (ottimamente).
      Ci vorranno circa <strong>5 minuti</strong>.
    </div>
  </div>

  <div class="container">
    <form method="POST" action="/test/<%= company.slug %>" id="quiz-form">

      <!-- Profilo -->
      <div class="section-header">
        <div class="section-dot"></div>
        <div class="section-name">Sezione 1 — Profilo</div>
        <div class="section-line"></div>
      </div>
      <div class="q-card" id="card-profile">
        <div class="profile-grid">
          <div class="field">
            <label for="rname">Nome e cognome</label>
            <input type="text" id="rname" name="respondent_name" class="text-input" required autocomplete="name">
          </div>
          <div class="field">
            <label for="rrole">Ruolo in azienda</label>
            <input type="text" id="rrole" name="respondent_role" class="text-input" placeholder="Es. Manager, Tecnico, Commerciale…" required>
          </div>
        </div>
      </div>

      <!-- Scored questions -->
      <%
        let currentSection = '';
        let sectionNum = 1;
        let qNum = 0;
        for (const q of questions) {
          qNum++;
          if (q.section !== currentSection) {
            currentSection = q.section;
            sectionNum++;
      %>
        <div class="section-header">
          <div class="section-dot"></div>
          <div class="section-name">Sezione <%= sectionNum %> — <%= q.section %></div>
          <div class="section-line"></div>
        </div>
      <% } %>

        <div class="q-card" id="card-q<%= q.id %>">
          <div class="q-num">Domanda <%= qNum %> / <%= questions.length %></div>
          <div class="q-text"><%= q.text %></div>
          <div class="scale-label <%= q.type %>">
            <% if (q.type === 'knowledge') { %>⬡<% } else { %>⬢<% } %>
            <%= scale[q.type].label %>
          </div>
          <div class="scale-row">
            <% for (let i = 1; i <= 5; i++) { %>
              <label class="scale-opt">
                <input type="radio" name="q<%= q.id %>" value="<%= i %>" required>
                <div class="scale-btn" onclick="">
                  <div class="num"><%= i %></div>
                  <div class="lbl"><%= scale[q.type].steps[i-1] %></div>
                </div>
              </label>
            <% } %>
          </div>
        </div>
      <% } %>

      <!-- Open questions -->
      <div class="section-header">
        <div class="section-dot"></div>
        <div class="section-name">Sezione Finale — Domande Aperte</div>
        <div class="section-line"></div>
      </div>
      <% for (const oq of openQuestions) { %>
        <div class="q-card open-q">
          <div class="q-text"><%= oq.text %></div>
          <textarea name="<%= oq.id %>" class="text-input" placeholder="Scrivi qui la tua risposta (facoltativo)…"></textarea>
        </div>
      <% } %>

      <div class="submit-area">
        <button type="submit" class="submit-btn" id="submit-btn">Invia autovalutazione →</button>
        <div class="submit-note">Le risposte sono riservate e serviranno a personalizzare il percorso formativo</div>
      </div>
    </form>
  </div>

  <div class="counter-bar">
    <span>Completamento: <strong id="pct-text">0%</strong></span>
    <span id="remaining-text"><%= questions.length %> domande da rispondere</span>
  </div>

  <script>
    const form = document.getElementById('quiz-form');
    const prog = document.getElementById('prog');
    const totalQ = <%= questions.length %>;

    function updateProgress() {
      let done = 0;
      const names = new Set();
      form.querySelectorAll('input[type=radio][required]').forEach(r => names.add(r.name));
      names.forEach(name => {
        if (form.querySelector(`input[name="${name}"]:checked`)) done++;
      });
      // also count text fields
      let textFilled = 0;
      form.querySelectorAll('input[type=text][required]').forEach(i => { if (i.value.trim()) textFilled++; });
      const total = names.size;
      const pct = total ? Math.round(done / total * 100) : 0;
      prog.style.width = pct + '%';
      document.getElementById('pct-text').textContent = pct + '%';
      const rem = total - done;
      document.getElementById('remaining-text').textContent = rem > 0 ? rem + ' domande da rispondere' : '✓ Tutto compilato!';

      // Mark cards as answered
      names.forEach(name => {
        const card = document.getElementById('card-' + name);
        if (card) card.classList.toggle('answered', !!form.querySelector(`input[name="${name}"]:checked`));
      });
    }

    form.addEventListener('change', updateProgress);
    form.addEventListener('input', updateProgress);

    form.addEventListener('submit', () => {
      const btn = document.getElementById('submit-btn');
      btn.disabled = true;
      btn.textContent = 'Invio in corso…';
    });

    updateProgress();
  </script>
</body>
</html>
