<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin — Login</title>
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="apple-touch-icon" sizes="192x192" href="/favicon-192.png">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f0f2f5; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .card { background: #fff; border-radius: 12px; padding: 48px 40px; box-shadow: 0 2px 12px rgba(0,0,0,.08); max-width: 400px; width: 100%; }
    h1 { font-size: 22px; color: #1a1a1a; margin-bottom: 8px; }
    p.sub { font-size: 14px; color: #666; margin-bottom: 32px; }
    label { display: block; font-size: 13px; font-weight: 600; color: #333; margin-bottom: 6px; }
    input[type=password] { width: 100%; padding: 10px 14px; border: 1px solid #ddd; border-radius: 8px; font-size: 15px; outline: none; transition: border .2s; }
    input[type=password]:focus { border-color: #2c3e50; }
    button { width: 100%; margin-top: 20px; padding: 12px; background: #2c3e50; color: #fff; border: none; border-radius: 8px; font-size: 15px; font-weight: 600; cursor: pointer; transition: background .2s; }
    button:hover { background: #1a252f; }
    .error { background: #fef2f2; color: #b91c1c; padding: 10px 14px; border-radius: 8px; font-size: 13px; margin-bottom: 20px; }
  </style>
</head>
<body>
  <div class="card">
    <img src="/logo.png" alt="Skillcraft" style="width:96px;height:96px;display:block;margin:0 auto 20px;object-fit:contain">
    <h1>Questionario AI</h1>
    <p class="sub">Accedi all'area amministrazione</p>
    <% if (error) { %><div class="error"><%= error %></div><% } %>
    <form method="POST" action="/admin/login">
      <label for="password">Password</label>
      <input type="password" id="password" name="password" autofocus required>
      <button type="submit">Accedi</button>
    </form>
  </div>
</body>
</html>
